# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo

# (#833) Per-deploy build id, generated by scripts/build-id.mjs during
# the artifacts' prebuild step. Must NOT be committed: a fresh deploy
# checkout has to start without it so the build resolves a real, current
# id for this deploy (git short hash, or a single deploy timestamp when
# git is unavailable).
.app-build-id

# Composite-project declaration outputs that consumers (api-server,
# h2budget) reference at typecheck time. These are generated from
# source by `pnpm --filter @workspace/api-spec run codegen` (which
# runs orval and then `tsc --build`), but `pnpm exec tsc --noEmit`
# bypasses lifecycle scripts, so the declaration outputs need to be
# present in a fresh checkout for direct typechecks to resolve
# cross-package types.
!lib/db/dist
!lib/db/dist/**
!lib/api-zod/dist
!lib/api-zod/dist/**
!lib/api-client-react/dist
!lib/api-client-react/dist/**
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
