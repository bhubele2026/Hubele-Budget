{
  "expo": {
    "name": "H2 Budget",
    "slug": "h2budget-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "h2budget",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0D",
    "splash": {
      "backgroundColor": "#0B0B0D",
      "resizeMode": "contain"
    },
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hubele.h2budget"
    },
    "android": {
      "package": "com.hubele.h2budget"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "router": { "origin": false },
      "apiBaseUrl": "https://hubele-budget.replit.app",
      "clerkPublishableKey": ""
    }
  }
}
