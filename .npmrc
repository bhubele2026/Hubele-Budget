auto-install-peers=false
strict-peer-dependencies=false
# Non-interactive (Replit autoscale deploy) install hardening. The deploy has
# no TTY, so pnpm cannot prompt before purging a node_modules left by a
# different pnpm version — let it purge + reinstall cleanly instead of
# aborting (ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY). verify-deps-before-run
# off so a fresh post-purge tree doesn't trip a spurious pre-script check.
confirm-modules-purge=false
verify-deps-before-run=false
